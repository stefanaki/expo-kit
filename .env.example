# OIDC / OpenID Connect configuration
# Copy this file to .env.local and fill in real values.
# All keys must be prefixed with EXPO_PUBLIC_ to be available at runtime in Expo.

# Required: The OIDC issuer URL (without trailing slash).
# Examples:
#   Auth0:     https://YOUR_TENANT.auth0.com
#   Keycloak:  https://YOUR_SERVER/realms/YOUR_REALM
#   Generic:   https://accounts.example.com
EXPO_PUBLIC_OIDC_ISSUER=https://YOUR_ISSUER_URL

# Required: The client_id for the Public Client registered with your OIDC provider.
# Authorization Code + PKCE flow is used; no client secret is needed.
EXPO_PUBLIC_OIDC_CLIENT_ID=YOUR_CLIENT_ID

# Optional: Space- or comma-separated scopes to request.
# Default: "openid profile email"
# EXPO_PUBLIC_OIDC_SCOPES=openid profile email offline_access

# Optional: audience parameter for providers that require it (e.g. Auth0 API access).
# EXPO_PUBLIC_OIDC_AUDIENCE=https://your-api-identifier
