{
  "cli": {
    "version": ">= 18.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_OIDC_ISSUER": "https://YOUR_ISSUER_URL",
        "EXPO_PUBLIC_OIDC_CLIENT_ID": "YOUR_CLIENT_ID"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_OIDC_ISSUER": "https://YOUR_ISSUER_URL",
        "EXPO_PUBLIC_OIDC_CLIENT_ID": "YOUR_CLIENT_ID"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_OIDC_ISSUER": "https://YOUR_ISSUER_URL",
        "EXPO_PUBLIC_OIDC_CLIENT_ID": "YOUR_CLIENT_ID"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
